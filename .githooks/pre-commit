#!/bin/sh
# コミット前にデータ・作図ルール・画面ロジックの点検を走らせる。失敗したらコミットを止める。
# 有効化（リポジトリで一度だけ）： git config core.hooksPath .githooks
# 一時的に飛ばしたいとき：       git commit --no-verify
if ! command -v npm >/dev/null 2>&1; then
  echo "pre-commit: npm が見つからないため点検をスキップしました" >&2
  exit 0
fi
# 依存（vitest / jsdom）が未取得なら入れる（初回のみ）。
if [ ! -d node_modules ]; then
  echo "pre-commit: 依存が無いので npm install を実行します（初回のみ）…"
  npm install --no-audit --no-fund --silent || exit 1
fi
echo "pre-commit: zu の点検を実行中…"
npm test --silent
