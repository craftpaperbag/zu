#!/bin/sh
# コミット前にデータ・作図ルールの点検を走らせる。失敗したらコミットを止める。
# 有効化（リポジトリで一度だけ）： git config core.hooksPath .githooks
# 一時的に飛ばしたいとき：       git commit --no-verify
if ! command -v node >/dev/null 2>&1; then
  echo "pre-commit: node が見つからないため点検をスキップしました" >&2
  exit 0
fi
echo "pre-commit: zu の点検を実行中…"
node --test "tests/*.test.js"
